# ============================================================================
# AVEX Backend — Environment Variables (example)
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================================

# ----- App -----
APP_NAME=avex-backend
APP_ENV=development                  # development | staging | production
APP_PORT=8080
APP_INSTANCE_ID=node-1               # unique per instance (for tracing/logs)
APP_LOG_LEVEL=info                   # debug | info | warn | error
APP_LOG_FORMAT=json                  # json | text

# ----- Database (PostgreSQL) -----
DATABASE_URL=postgres://user:pass@localhost:5432/avex?sslmode=disable
DATABASE_MAX_CONNS=25
DATABASE_MIN_CONNS=5
DATABASE_MAX_CONN_LIFETIME=30m
DATABASE_MAX_CONN_IDLE_TIME=5m

# ----- Redis (event bus + cache + presence) -----
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_POOL_SIZE=20

# ----- JWT -----
JWT_SECRET=change-me-in-production-min-32-chars
JWT_ISSUER=avex
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL=720h                 # 30 days

# ----- Password Hashing (bcrypt) -----
BCRYPT_COST=12                       # 10-14 recommended

# ----- OpenTelemetry -----
OTEL_EXPORTER=stdout                 # stdout | otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=avex-backend
OTEL_SAMPLER_RATIO=1.0               # 1.0 = always sample (dev), 0.05 in prod

# ----- CORS -----
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept,X-Request-Id
CORS_ALLOW_CREDENTIALS=true

# ----- Secrets Provider -----
SECRETS_PROVIDER=env                 # env | file | vault
SECRETS_FILE_PATH=                   # used when SECRETS_PROVIDER=file
# VAULT_ADDR=                        # used when SECRETS_PROVIDER=vault
# VAULT_TOKEN=

# ----- Outbox Publisher Worker -----
OUTBOX_POLL_INTERVAL=500ms
OUTBOX_BATCH_SIZE=100
OUTBOX_MAX_RETRIES=10
OUTBOX_RETRY_BASE_DELAY=1s

# ----- PII Encryption (future) -----
# PII_ENCRYPTION_KEY=               # 32-byte base64 key (only when PII encryption enabled)
# PII_HMAC_KEY=                     # 32-byte base64 key (only when PII encryption enabled)
